{
  "info": {
    "_postman_id": "de7a3c2a-0000-4000-8000-000000000000",
    "name": "Devmind Fullstack Project - API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test123\",\n  \"email\": \"test@example.com\",\n  \"firstName\": \"Test\",\n  \"name\": \"User\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/register", "host": ["{{baseUrl}}"], "path": ["api","v1","register"] }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test123\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/login", "host": ["{{baseUrl}}"], "path": ["api","v1","login"] }
      }
    },
    {
      "name": "Validate Token",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/validate-token", "host": ["{{baseUrl}}"], "path": ["api","v1","validate-token"] }
      }
    },
    {
      "name": "Whoami",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/whoami", "host": ["{{baseUrl}}"], "path": ["api","v1","whoami"] }
      }
    },
    {
      "name": "Get All Vendors",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/vendors", "host": ["{{baseUrl}}"], "path": ["api","v1","vendors"] } }
    },
    {
      "name": "Get Vendor By Id",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/vendors/1", "host": ["{{baseUrl}}"], "path": ["api","v1","vendors","1"] } }
    },
    {
      "name": "Add Vendor",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"companyName\": \"Acme Services\",\n  \"companyEmail\": \"acme@example.com\",\n  \"location\": \"Bucharest\",\n  \"websiteUrl\": \"https://acme.example.com\",\n  \"phoneNumber\": \"+40700111222\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/vendors/add", "host": ["{{baseUrl}}"], "path": ["api","v1","vendors","add"] }
      }
    },
    {
      "name": "Get Vendor Services",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/vendors/1/services", "host": ["{{baseUrl}}"], "path": ["api","v1","vendors","1","services"] } }
    },
    {
      "name": "Add Vendor Service",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Plumbing - Basic Fix\",\n  \"description\": \"Fix leaks and clogs\",\n  \"category\": \"Plumbing\",\n  \"vendorId\": 1\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/vendors/1/services/add", "host": ["{{baseUrl}}"], "path": ["api","v1","vendors","1","services","add"] }
      }
    },
    {
      "name": "Create Review",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Great service\",\n  \"body\": \"They were quick and professional\",\n  \"rating\": 5,\n  \"serviceId\": 1\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/reviews/create-new-review", "host": ["{{baseUrl}}"], "path": ["api","v1","reviews","create-new-review"] }
      }
    },
    {
      "name": "Get Reviews For Service",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/reviews/service/1", "host": ["{{baseUrl}}"], "path": ["api","v1","reviews","service","1"] } }
    },
    {
      "name": "Update Review",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated title\",\n  \"body\": \"Updated body\",\n  \"rating\": 4\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/reviews/1/edit", "host": ["{{baseUrl}}"], "path": ["api","v1","reviews","1","edit"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "token", "value": "" }
  ]
}
